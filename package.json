{
  "name": "test-web-app",
  "private": "true",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node --import @azure/monitor-opentelemetry/loader server.js",
    "test": "curl -v https://mikeharder-test-web-app.azurewebsites.net",
    "test:health": "curl -v https://mikeharder-test-web-app.azurewebsites.net/health",
    "deploy": "az webapp up --name mikeharder-test-web-app --resource-group mikeharder-test-plan --plan mikeharder-test-plan --runtime \"NODE:24-lts\" --sku P0V4 --os-type Linux --location westus2"
  },
  "dependencies": {
    "@azure/monitor-opentelemetry": "^1.16.0",
    "@opentelemetry/api": "^1.9.1",
    "dotenv": "^17.4.2"
  }
}
