{
  "name": "test-web-app",
  "private": "true",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node --import ./instrumentation.js server.js",
    "test": "curl -v https://mikeharder-test-web-app.azurewebsites.net",
    "test:health": "curl -v https://mikeharder-test-web-app.azurewebsites.net/health",
    "deploy": "NAME=mikeharder-test-web-app && az webapp up --name $NAME --resource-group $NAME --plan $NAME --runtime \"NODE:24-lts\" --sku B1 --os-type Linux --location westus2"
  },
  "dependencies": {
    "@azure/monitor-opentelemetry": "^1.16.0",
    "@opentelemetry/api": "^1.9.1",
    "dotenv": "^17.4.2"
  }
}
